// !! GOOD CODE EXAMPLE !!
VkImage swapchain_images[num_swapchain_images]

// Resources indexed by the current in-flight frame index
const MAX_FRAMES_IN_FLIGHT = 2
VkFence frame_fences[MAX_FRAMES_IN_FLIGHT];
VkSemaphore m_imageAvailableSemaphores[MAX_FRAMES_IN_FLIGHT];
VkCommandBuffer command_buffers[MAX_FRAMES_IN_FLIGHT];
int m_currentFrame = 0; // 0..MAX_FRAMES_IN_FLIGHT-1

// Semaphores that are waited on by QueuePresent are buffered based on the number of swapchain images
VkSemaphore submit_semaphores[swapchain_image_count]

while (!quit) {
    VkFence m_inFlightFences = frame_fences[m_currentFrame]
    vkWaitForFences(m_inFlightFences)
    vkResetFences(m_inFlightFences)

    uint32_t imageIndex;
    VkSemaphore acquire_semaphore = m_imageAvailableSemaphores[m_currentFrame]
    vkAcquireNextImageKHR(swapchain, acquire_semaphore, &imageIndex)

    // Index submit semaphore with the acquired swapchain image index.
    // It's the only resource in this example indexed by imageIndex.
    // All other resources, including acquire_semaphore, are indexed with current in-flight frame index.
    VkSemaphore submit_semaphore = submit_semaphores[imageIndex]

    VkCommandBuffer command_buffer = command_buffers[m_currentFrame]
    vkBeginCommandBuffer(command_buffer)
    RecordCommands(command_buffer)
    vkEndCommandBuffer(command_buffer)

    VkSubmitInfo submit_info
    submit_info.pWaitSemaphores = &acquire_semaphore
    submit_info.pCommandBuffers = &command_buffer
    submit_info.pSignalSemaphores = &submit_semaphore
    vkQueueSubmit(queue, &submit_info, m_inFlightFences)

    VkPresentInfo present_info
    present_info.pWaitSemaphores = &submit_semaphore
    present_info.pSwapchains = &swapchain
    present_info.pImageIndices = &imageIndex
    vkQueuePresent(queue, &present_info)

    m_currentFrame = (m_currentFrame + 1) % MAX_FRAMES_IN_FLIGHT
}